{
  "version": 1,
  "version": 1,
  "keys": {
    "tracker": {
      "secret": "wincred:tracker-pat",
      "upstream": "https://issues.example.com",
      "inject": [ { "kind": "header", "name": "Authorization", "template": "Bearer {secret}" } ],
      "actions": {
        "read": {
          "rules": [
            { "methods": ["GET"], "path": "/rest/api/2/issue/PROJ-*" }
          ]
        }
      }
    }
  }
}
