+function buildRoomRunSpecFromFlags(opts: ShipOpts): ShipRoom {
+  const draft: Record<string, unknown> = {};
+  if (opts.roomRepo !== undefined) {
+    draft["repos"] = [
+      {
+        url: opts.roomRepo,
+        ...(opts.roomStartingRef !== undefined && { startingRef: opts.roomStartingRef }),
+      },
