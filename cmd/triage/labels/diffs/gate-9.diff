+	if err := json.Unmarshal(grants[0].Body, &g); err != nil {
+		t.Fatal(err)
+	}
+	if g.MaxCycles != 3 {
+		t.Fatalf("default -max-cycles minted %d, want 3", g.MaxCycles)
+	}
+}
