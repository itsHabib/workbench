+	if err != nil {
+		t.Fatal(err)
+	}
+	grants, err := st.List(func(a state.Artifact) bool { return a.Kind == state.KindGrant })
+	if err != nil {
+		t.Fatal(err)
+	}
+	if len(grants) != 1 {
+		t.Fatalf("want one grant, got %d", len(grants))
+	}
