diff --git a/internal/blox/genplan/cost.go b/internal/blox/genplan/cost.go
new file mode 100644
index 0000000..3187c4d
--- /dev/null
+++ b/internal/blox/genplan/cost.go
@@ -0,0 +1,35 @@
+package genplan
+
+import (
+	"log/slog"
+
+	"github.com/wellness-ai/wellness-ai/internal/blox"
+)
+
+// modelRates holds USD-per-million-token pricing for one model.
+type modelRates struct {
+	inputPerM  int64 // micro-dollars per 1M input tokens
+	outputPerM int64 // micro-dollars per 1M output tokens
+}
+
+// modelRateTable is the per-model pricing used to estimate generation cost.
+// Unknown models return 0 — never guess.
+var modelRateTable = map[string]modelRates{
+	DefaultModel:        {inputPerM: 5_000_000, outputPerM: 25_000_000},  // opus-4-8: $5/$25
+	"claude-sonnet-4-6": {inputPerM: 3_000_000, outputPerM: 15_000_000}, // $3/$15
+	"claude-haiku-4-5":  {inputPerM: 1_000_000, outputPerM: 5_000_000},  // $1/$5
+}
+
+// CostMicros estimates USD cost in micro-dollars (1 USD = 1_000_000 micros)
+// from model rates and token usage. Cache tokens are captured on Usage but
+// not priced here — only billed input and output tokens count.
+func CostMicros(model string, u blox.Usage) int64 {
+	rates, ok := modelRateTable[model]
+	if !ok {
+		slog.Warn("genplan: unknown model for cost estimate", "model", model)
+		return 0
+	}
+	in := int64(u.InputTokens) * rates.inputPerM
+	out := int64(u.OutputTokens) * rates.outputPerM
+	return (in + out) / 1_000_000
+}
