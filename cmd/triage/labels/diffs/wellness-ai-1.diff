new file mode 100644
index 0000000..58412d2
--- /dev/null
+++ b/internal/blox/genplan/cost_test.go
@@ -0,0 +1,36 @@
+package genplan
+
+import (
+	"testing"
+
+	"github.com/wellness-ai/wellness-ai/internal/blox"
+)
+
+func TestCostMicros(t *testing.T) {
+	tests := []struct {
+		name  string
+		model string
+		usage blox.Usage
+		want  int64
+	}{
+		{
+			name:  "opus-4-8 input and output",
+			model: DefaultModel,
+			usage: blox.Usage{InputTokens: 1_000_000, OutputTokens: 1_000_000},
+			want:  30_000_000, // $5 input + $25 output
+		},
+		{
+			name:  "unknown model returns zero",
+			model: "claude-unknown-99",
+			usage: blox.Usage{InputTokens: 1_000_000, OutputTokens: 1_000_000},
+			want:  0,
+		},
+	}
+	for _, tc := range tests {
+		t.Run(tc.name, func(t *testing.T) {
+			if got := CostMicros(tc.model, tc.usage); got != tc.want {
+				t.Errorf("CostMicros() = %d, want %d", got, tc.want)
+			}
+		})
+	}
+}
