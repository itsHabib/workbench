diff --git a/.github/workflows/audit.yml b/.github/workflows/audit.yml
new file mode 100644
index 0000000..5a04a40
--- /dev/null
+++ b/.github/workflows/audit.yml
@@ -0,0 +1,29 @@
+name: audit
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+
+permissions:
+  contents: read
+  checks: write
+
+jobs:
+  audit:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      # Advisory ignores — each entry needs a one-line justification (mirrors
+      # the repo's #[allow]-needs-a-reason posture). All three are transitive
+      # via aws-sdk-s3 -> rustls-webpki 0.101.7 with no non-breaking bump yet;
+      # remediation (bump the rustls stack) is tracked separately. The 2 unsound
+      # warnings (libyml / serde_yml) are intentionally NOT ignored so they stay
+      # visible until the serde_yml migration lands.
+      #   RUSTSEC-2026-0104  rustls-webpki CRL-parse panic (DoS); dossier's S3 TLS hits a trusted endpoint and parses no CRLs
+      #   RUSTSEC-2026-0099  rustls-webpki wildcard name-constraint; misissuance-gated, reachable only after signature verification
+      #   RUSTSEC-2026-0098  rustls-webpki URI name-constraint; misissuance-gated, and dossier asserts no URI names
+      - uses: rustsec/audit-check@v2.0.0
+        with:
+          token: ${{ secrets.GITHUB_TOKEN }}
+          ignore: RUSTSEC-2026-0104,RUSTSEC-2026-0099,RUSTSEC-2026-0098
