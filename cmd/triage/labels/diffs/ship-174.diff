diff --git a/.github/workflows/claude.yml b/.github/workflows/claude.yml
index 3e40ed7..98a02b9 100644
--- a/.github/workflows/claude.yml
+++ b/.github/workflows/claude.yml
@@ -25,12 +25,43 @@ jobs:
       id-token: write
       actions: read # Required for Claude to read CI results on PRs
     steps:
+      # The action diffs via `git hash-object <path>` against the working
+      # tree, so files a PR adds must exist on disk — a main checkout (any
+      # fetch depth) lacks them and the review dies before it starts. Check
+      # out the PR head instead, but ONLY when the head lives in this repo:
+      # in-repo branches require push access, so their content is as trusted
+      # as the commenter the action already gates on. A fork head never
+      # replaces the trusted workspace — fork PRs keep the main checkout.
+      - name: Resolve review ref (PR head for same-repo PRs)
+        id: review_ref
+        env:
+          GH_TOKEN: ${{ github.token }}
+          PR_NUMBER: >-
+            ${{
+              (github.event_name == 'issue_comment' && github.event.issue.pull_request
+                && github.event.issue.number)
+              || ((github.event_name == 'pull_request_review'
+                  || github.event_name == 'pull_request_review_comment')
+                && github.event.pull_request.number)
+              || ''
+            }}
+        run: |
+          set -euo pipefail
+          ref="${GITHUB_REF}"
+          if [ -n "${PR_NUMBER}" ]; then
+            same_repo=$(gh api "repos/${GITHUB_REPOSITORY}/pulls/${PR_NUMBER}" \
+              --jq '.head.repo.full_name == .base.repo.full_name')
+            if [ "${same_repo}" = "true" ]; then
+              ref="refs/pull/${PR_NUMBER}/head"
+            fi
+          fi
+          echo "resolved review ref: ${ref}"
+          echo "ref=${ref}" >> "${GITHUB_OUTPUT}"
+
       - name: Checkout repository
         uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4 — audited 2026-06-12
         with:
-          # Full history: the action's tag-mode diff (git hash-object) needs
-          # PR-branch blobs that a depth-1 checkout of main lacks, so a shallow
-          # fetch kills @claude review on any PR that adds files.
+          ref: ${{ steps.review_ref.outputs.ref }}
           fetch-depth: 0
 
       - name: Run Claude Code
