@@ -0,0 +1,25 @@
+-- Revert 027: restore the 025 partial indexes (without INCLUDE event_id) and
+-- drop the covering replacements. Mirror image of the up migration.
+
+CREATE INDEX IF NOT EXISTS idx_results_leaderboard_division_time
+    ON results (division, total_time)
+    WHERE run_1 IS NOT NULL AND run_2 IS NOT NULL AND run_3 IS NOT NULL
+      AND run_4 IS NOT NULL AND run_5 IS NOT NULL AND run_6 IS NOT NULL
+      AND run_7 IS NOT NULL AND run_8 IS NOT NULL
+      AND ski_erg IS NOT NULL AND sled_push IS NOT NULL AND sled_pull IS NOT NULL
+      AND burpee_broad_jump IS NOT NULL AND rowing IS NOT NULL
+      AND farmer_carry IS NOT NULL AND sandbag_lunge IS NOT NULL
+      AND wall_balls IS NOT NULL AND roxzone IS NOT NULL;
+
+CREATE INDEX IF NOT EXISTS idx_results_leaderboard_division_age_time
+    ON results (division, age_group, total_time)
+    WHERE run_1 IS NOT NULL AND run_2 IS NOT NULL AND run_3 IS NOT NULL
+      AND run_4 IS NOT NULL AND run_5 IS NOT NULL AND run_6 IS NOT NULL
+      AND run_7 IS NOT NULL AND run_8 IS NOT NULL
+      AND ski_erg IS NOT NULL AND sled_push IS NOT NULL AND sled_pull IS NOT NULL
+      AND burpee_broad_jump IS NOT NULL AND rowing IS NOT NULL
+      AND farmer_carry IS NOT NULL AND sandbag_lunge IS NOT NULL
+      AND wall_balls IS NOT NULL AND roxzone IS NOT NULL;
+
+DROP INDEX IF EXISTS idx_results_lb_division_time;
+DROP INDEX IF EXISTS idx_results_lb_division_age_time;
diff --git a/migrations/027_leaderboard_stats_covering_index.up.sql b/migrations/027_leaderboard_stats_covering_index.up.sql
new file mode 100644
index 0000000..312ce91
--- /dev/null
+++ b/migrations/027_leaderboard_stats_covering_index.up.sql
@@ -0,0 +1,53 @@
+-- 027_leaderboard_stats_covering_index.up.sql
+-- Make the leaderboard STATS query (COUNT(*) + MIN(ranking column) -- the
+-- pagination total and the gap-to-leader anchor) index-only for the default
+-- total_time ranking. (Station-sorted leaderboards rank by a station column,
+-- which these indexes do not cover -- that path still seq-scans; out of scope.)
+--
+-- 025 added partial indexes on (division, total_time) [+ age_group], which made
+-- the PAGE query an index range scan. But the STATS query excludes ~5
+-- non-standard events (youngstars / browney / red-bull-monday-night-shift) by
+-- JOINing events and applying `e.name NOT ILIKE`. That join forced the planner
+-- off the index onto a parallel Seq Scan of all ~1.76M results rows -- ~4.8s on
+-- prod, the real cost behind the slow GET /api/leaderboards. (Proven via
+-- EXPLAIN: COUNT without the events join = 375ms index-only; WITH it = 4808ms.)
+--
+-- The stats query now drops the join and filters `event_id IN (events subquery)`
+-- instead (internal/store/store.go buildLeaderboardStatsQuery). For that to stay
+-- index-only the event_id must be readable FROM the index, so these indexes
+-- carry it as an INCLUDE column. The INCLUDE versions serve everything the 025
+-- originals did (same key prefix + predicate), so they supersede and replace
+-- them.
+--
+-- New index NAMES (not the 025 names) so this migration is idempotent under the
+-- no-tracking, re-apply-all migrate-up runner: CREATE IF NOT EXISTS the new
+-- ones, then DROP IF EXISTS the old ones -- both no-ops on every re-run. CREATE
+-- runs before DROP so there is never a window with no usable index.
+--
+-- On prod, prefer CREATE/DROP INDEX CONCURRENTLY (run each as a standalone
+-- statement, outside a transaction) to avoid the brief write lock on results;
+-- plain CREATE/DROP is used here so the file applies cleanly via `make
+-- migrate-up` and the Neon SQL Editor. results is append-mostly, lock is short.
+
+CREATE INDEX IF NOT EXISTS idx_results_lb_division_time
+    ON results (division, total_time) INCLUDE (event_id)
+    WHERE run_1 IS NOT NULL AND run_2 IS NOT NULL AND run_3 IS NOT NULL
+      AND run_4 IS NOT NULL AND run_5 IS NOT NULL AND run_6 IS NOT NULL
+      AND run_7 IS NOT NULL AND run_8 IS NOT NULL
+      AND ski_erg IS NOT NULL AND sled_push IS NOT NULL AND sled_pull IS NOT NULL
+      AND burpee_broad_jump IS NOT NULL AND rowing IS NOT NULL
+      AND farmer_carry IS NOT NULL AND sandbag_lunge IS NOT NULL
+      AND wall_balls IS NOT NULL AND roxzone IS NOT NULL;
+
+CREATE INDEX IF NOT EXISTS idx_results_lb_division_age_time
+    ON results (division, age_group, total_time) INCLUDE (event_id)
+    WHERE run_1 IS NOT NULL AND run_2 IS NOT NULL AND run_3 IS NOT NULL
+      AND run_4 IS NOT NULL AND run_5 IS NOT NULL AND run_6 IS NOT NULL
+      AND run_7 IS NOT NULL AND run_8 IS NOT NULL
+      AND ski_erg IS NOT NULL AND sled_push IS NOT NULL AND sled_pull IS NOT NULL
+      AND burpee_broad_jump IS NOT NULL AND rowing IS NOT NULL
+      AND farmer_carry IS NOT NULL AND sandbag_lunge IS NOT NULL
+      AND wall_balls IS NOT NULL AND roxzone IS NOT NULL;
+
+DROP INDEX IF EXISTS idx_results_leaderboard_division_time;
+DROP INDEX IF EXISTS idx_results_leaderboard_division_age_time;
