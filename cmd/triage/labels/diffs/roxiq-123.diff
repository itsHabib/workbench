+++ b/internal/store/leaderboard_query_test.go
@@ -0,0 +1,134 @@
+package store
+
+import (
+	"regexp"
+	"strconv"
+	"strings"
+	"testing"
+
+	"github.com/roxiq/roxiq/internal/model"
+)
+
+// Pure-unit coverage for the leaderboard SQL builders (no DB). Guards the
+// 027 refactor: the stats query drops the events JOIN (which forced a full
+// seq scan) for an `event_id IN (events subquery)`, and the result/event
+// clause split must keep $N placeholders aligned with the shared args slice.
+
+var paramRe = regexp.MustCompile(`\$(\d+)`)
+
+// maxParam returns the highest $N referenced in q.
+func maxParam(q string) int {
+	highest := 0
+	for _, m := range paramRe.FindAllStringSubmatch(q, -1) {
+		if n, _ := strconv.Atoi(m[1]); n > highest {
+			highest = n
+		}
+	}
+	return highest
+}
+
+func TestBuildLeaderboardStatsQuery_NoEventsJoin(t *testing.T) {
+	w, err := buildLeaderboardWhere(model.LeaderboardFilters{Division: "men_open"})
+	if err != nil {
+		t.Fatalf("buildLeaderboardWhere: %v", err)
+	}
+	q, args := buildLeaderboardStatsQuery(&w)
+
+	if strings.Contains(q, "JOIN events") {
+		t.Fatalf("stats query must NOT join events (the join forces a seq scan):\n%s", q)
+	}
+	if !strings.Contains(q, "event_id IN (SELECT") {
+		t.Fatalf("stats query must exclude events via an event_id IN subquery:\n%s", q)
+	}
+	if !strings.Contains(q, "NOT ILIKE") {
+		t.Fatalf("stats subquery must carry the event-name exclusions:\n%s", q)
+	}
+	if got := maxParam(q); got != len(args) {
+		t.Fatalf("stats: max param $%d != len(args) %d (placeholder/arg mismatch)\n%s", got, len(args), q)
+	}
+}
+
+func TestBuildLeaderboardPageQuery_JoinsEvents(t *testing.T) {
+	w, err := buildLeaderboardWhere(model.LeaderboardFilters{Division: "men_open"})
+	if err != nil {
+		t.Fatalf("buildLeaderboardWhere: %v", err)
+	}
+	q, args := buildLeaderboardPageQuery(&w, 20, 0)
+
+	if !strings.Contains(q, "JOIN events e") {
+		t.Fatalf("page query must JOIN events for e.name/e.season output:\n%s", q)
+	}
+	if got := maxParam(q); got != len(args) {
+		t.Fatalf("page: max param $%d != len(args) %d\n%s", got, len(args), q)
+	}
+}
+
+func TestBuildLeaderboard_SeasonFilterLivesInStatsSubquery(t *testing.T) {
+	w, err := buildLeaderboardWhere(model.LeaderboardFilters{Division: "men_open", Season: 8})
+	if err != nil {
+		t.Fatalf("buildLeaderboardWhere: %v", err)
+	}
+	q, args := buildLeaderboardStatsQuery(&w)
+
+	sub := strings.Index(q, "(SELECT")
+	if sub < 0 {
+		t.Fatalf("expected an events subquery:\n%s", q)
+	}
+	// results has no season column; the season predicate must sit inside the
+	// events subquery, never in the outer results scan.
+	if !strings.Contains(q[sub:], "e.season =") {
+		t.Fatalf("season filter must be inside the events subquery:\n%s", q)
+	}
+	if strings.Contains(q[:sub], "season") {
+		t.Fatalf("season must not appear in the outer results predicate:\n%s", q)
+	}
+	if got := maxParam(q); got != len(args) {
+		t.Fatalf("stats(season): max param $%d != len(args) %d\n%s", got, len(args), q)
+	}
+}
+
+func TestBuildLeaderboard_ExclusionPatternsLiveInStatsSubquery(t *testing.T) {
+	w, err := buildLeaderboardWhere(model.LeaderboardFilters{Division: "men_open"})
+	if err != nil {
+		t.Fatalf("buildLeaderboardWhere: %v", err)
+	}
+	q, _ := buildLeaderboardStatsQuery(&w)
+
+	sub := strings.Index(q, "(SELECT")
+	if sub < 0 {
+		t.Fatalf("expected an events subquery:\n%s", q)
+	}
+	// the name exclusions reference e.name and MUST sit inside the events
+	// subquery -- results has no name column, so an outer-scan NOT ILIKE would
+	// be a SQL error (and re-introducing the join is the perf regression).
+	if strings.Contains(q[:sub], "NOT ILIKE") {
+		t.Fatalf("event-name exclusions must be inside the subquery, not the outer results scan:\n%s", q)
+	}
+	if !strings.Contains(q[sub:], "NOT ILIKE") {
+		t.Fatalf("event-name exclusions missing from the events subquery:\n%s", q)
+	}
+}
+
+func TestBuildLeaderboard_StationSortStillAvoidsJoin(t *testing.T) {
+	w, err := buildLeaderboardWhere(model.LeaderboardFilters{Division: "men_open", Station: "ski_erg"})
+	if err != nil {
+		t.Fatalf("buildLeaderboardWhere: %v", err)
+	}
+	q, args := buildLeaderboardStatsQuery(&w)
+
+	if strings.Contains(q, "JOIN events") {
+		t.Fatalf("station-sorted stats must still avoid the events join:\n%s", q)
+	}
+	if !strings.Contains(q, "MIN(r.ski_erg)") {
+		t.Fatalf("station sort should MIN the station column:\n%s", q)
+	}
+	if got := maxParam(q); got != len(args) {
+		t.Fatalf("stats(station): max param $%d != len(args) %d\n%s", got, len(args), q)
+	}
+}
+
+func TestBuildLeaderboard_InvalidStationRejected(t *testing.T) {
+	if _, err := buildLeaderboardWhere(model.LeaderboardFilters{Division: "men_open", Station: "not_a_station"}); err == nil {
+		t.Fatal("expected an error for an invalid station column (SQL-injection guard)")
+	}
+}
