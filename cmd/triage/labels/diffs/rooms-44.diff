+        }
+
+        if !rootfs.exists() {
+            failures.push(format!("rootfs missing at {}", rootfs.display()));
+        } else if !path_readable_by_uid(&rootfs, uid) {
+            failures.push(format!(
+                "{FIRECRACKER_USER} cannot read rootfs at {} (check group/other permissions)",
