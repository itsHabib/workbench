+
+        let mut failures = Vec::new();
+        if let Some(path) = kernel {
+            if !path.exists() {
+                failures.push(format!("kernel missing at {}", path.display()));
+            } else if !path_readable_by_uid(&path, uid) {
+                failures.push(format!(
