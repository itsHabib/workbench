+pub fn tap_owned_by_user(tuntap_output: &str, user: &str) -> bool {
+    tuntap_output
+        .split_whitespace()
+        .collect::<Vec<_>>()
+        .windows(2)
+        .any(|pair| pair.first() == Some(&"user") && pair.get(1) == Some(&user))
+}
