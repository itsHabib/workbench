index 0000000..a92673e
--- /dev/null
+++ b/cmd/deploy-secret-lint/main_test.go
@@ -0,0 +1,119 @@
+package main
+
+import (
+	"strings"
+	"testing"
+)
+
+// A representative prod secrets.tf: four count-gated secrets (each as the
+// secret + its version, both gated) plus an UNGATED database_url.
+const secretsTF4 = `
+resource "google_secret_manager_secret" "database_url" {
+  secret_id = "roxiq-database-url-prod"
+}
+resource "google_secret_manager_secret" "sentry_dsn" {
+  count     = var.sentry_dsn == "" ? 0 : 1
+  secret_id = "roxiq-sentry-dsn-prod"
+}
+resource "google_secret_manager_secret_version" "sentry_dsn" {
+  count  = var.sentry_dsn == "" ? 0 : 1
+  secret = google_secret_manager_secret.sentry_dsn[0].id
+}
+resource "google_secret_manager_secret" "slack_webhook_url" {
+  count = var.slack_webhook_url == "" ? 0 : 1
+}
+resource "google_secret_manager_secret" "subscriber_slack_webhook_url" {
+  count = var.subscriber_slack_webhook_url == "" ? 0 : 1
+}
+resource "google_secret_manager_secret" "vercel_drain_secret" {
+  count = var.vercel_drain_secret == "" ? 0 : 1
+}
+`
+
+// A deploy-prod.yml apply-step env block passing all four (mirrors the real file).
+const deployOK = `
+        env:
+          TF_VAR_database_url: ${{ secrets.PROD_DATABASE_URL }}
+          TF_VAR_sentry_dsn: ${{ secrets.PROD_SENTRY_DSN }}
+          TF_VAR_slack_webhook_url: ${{ secrets.PROD_SLACK_WEBHOOK_URL }}
+          TF_VAR_subscriber_slack_webhook_url: ${{ secrets.PROD_SUBSCRIBER_SLACK_WEBHOOK_URL }}
+          TF_VAR_vercel_drain_secret: ${{ secrets.PROD_VERCEL_DRAIN_SECRET }}
+`
+
+func TestCountGated(t *testing.T) {
+	got := strings.Join(countGated(secretsTF4), ",")
+	want := "sentry_dsn,slack_webhook_url,subscriber_slack_webhook_url,vercel_drain_secret"
+	if got != want {
+		t.Fatalf("countGated = %q, want %q (database_url is ungated and must be excluded)", got, want)
+	}
+}
+
+func TestLint(t *testing.T) {
+	tests := []struct {
+		name      string
+		secretsTF string
+		deployYML string
+		wantViol  int
+		wantName  string // a secret name expected in the violation messages
+	}{
+		{
+			name:      "all four present passes (the current-main case)",
+			secretsTF: secretsTF4,
+			deployYML: deployOK,
+			wantViol:  0,
+		},
+		{
+			name:      "dropped vercel_drain_secret is caught (the §11 fixture)",
+			secretsTF: secretsTF4,
+			deployYML: strings.ReplaceAll(deployOK,
+				"          TF_VAR_vercel_drain_secret: ${{ secrets.PROD_VERCEL_DRAIN_SECRET }}\n", ""),
+			wantViol: 1,
+			wantName: "vercel_drain_secret",
+		},
+		{
+			name:      "commented-out secret reads as omitted",
+			secretsTF: secretsTF4,
+			deployYML: strings.ReplaceAll(deployOK,
+				"          TF_VAR_vercel_drain_secret:", "          # TF_VAR_vercel_drain_secret:"),
+			wantViol: 1,
+			wantName: "vercel_drain_secret",
+		},
+		{
+			name:      "empty-string literal is caught",
+			secretsTF: secretsTF4,
+			deployYML: strings.ReplaceAll(deployOK,
+				"${{ secrets.PROD_VERCEL_DRAIN_SECRET }}", `""`),
+			wantViol: 1,
+			wantName: "vercel_drain_secret",
+		},
+		{
+			name: "a newly-added count-gated secret without a TF_VAR is caught (self-maintaining)",
+			secretsTF: secretsTF4 + `
+resource "google_secret_manager_secret" "new_secret" {
+  count = var.new_secret == "" ? 0 : 1
+}
+`,
+			deployYML: deployOK,
+			wantViol:  1,
+			wantName:  "new_secret",
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			got := lint(tt.secretsTF, tt.deployYML)
+			if len(got) != tt.wantViol {
+				t.Fatalf("lint returned %d violation(s), want %d: %v", len(got), tt.wantViol, got)
+			}
+			if tt.wantName == "" {
+				return
+			}
+			for _, v := range got {
+				if strings.Contains(v, tt.wantName) {
+					return
+				}
+			}
+			t.Errorf("expected a violation mentioning %q, got %v", tt.wantName, got)
+		})
+	}
+}
