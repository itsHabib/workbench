+name: deploy-secret-lint
+
+# Required pre-merge gate (Phase 2). Asserts deploy-prod.yml passes a
+# TF_VAR_<name> for every count-gated prod secret — the set DERIVED from
+# infra/terraform/environments/prod/secrets.tf — so a deploy can never silently
+# drop one (the 2026-06-13 VERCEL_DRAIN_SECRET incident). Pure text: no GCP, no
+# secrets, ~seconds, so it auto-triggers on every PR and is cheap to require.
+# The deployed HTTP/browser suite (cmd/sanity) stays on-demand (/sanity) +
+# post-merge (verify-prod) — it can't be a cheap required pre-merge check.
+#
+# Mark the `deploy-secret-lint` check required in branch protection
+# (dossier task e2e-sanity-require-deploy-secret-lint).
+
+on:
+  pull_request:
+    branches: [main]
+  push:
+    branches: [main]
+
+permissions:
+  contents: read
+
+jobs:
+  deploy-secret-lint:
+    name: deploy-secret-lint
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+
+      - uses: actions/setup-go@v5
+        with:
+          go-version-file: go.mod
+
+      - name: Assert deploy-prod.yml wires every count-gated prod secret
+        run: go run ./cmd/deploy-secret-lint
diff --git a/cmd/deploy-secret-lint/main.go b/cmd/deploy-secret-lint/main.go
new file mode 100644
index 0000000..5c657c0
--- /dev/null
+++ b/cmd/deploy-secret-lint/main.go
@@ -0,0 +1,136 @@
+// Command deploy-secret-lint is a pre-merge gate: it asserts deploy-prod.yml
+// passes a TF_VAR_<name> for every count-gated prod secret, so a deploy can
+// never silently drop one. The 2026-06-13 incident: an omitted
+// TF_VAR_vercel_drain_secret made `terraform apply` DESTROY the Secret Manager
+// secret + strip the VERCEL_DRAIN_SECRET env from the api service, 404-ing the
+// Vercel drain endpoint — caught only manually, days later.
+//
+// The set of count-gated secrets is DERIVED from secrets.tf (the resources
+// gated on `count = var.x == "" ? 0 : 1`), not hardcoded, so adding a new
+// count-gated secret can't silently bypass the lint.
+//
+// Pure text: no GCP, no secrets, no terraform — runs in ~seconds, so it's a
+// cheap auto-triggered required check (unlike the deployed HTTP suite, which
+// needs a deployed target and belongs post-merge).
+//
+// Usage:
+//
+//	deploy-secret-lint [--secrets-tf <path>] [--deploy-workflow <path>]
+//
+// Exit 0 when every count-gated secret has a TF_VAR_<name> wired to a
+// ${{ secrets.* }} reference; 1 otherwise, printing each violation.
+package main
+
+import (
+	"flag"
+	"fmt"
+	"os"
+	"regexp"
+	"sort"
+	"strings"
+)
+
+const (
+	defaultSecretsTF      = "infra/terraform/environments/prod/secrets.tf"
+	defaultDeployWorkflow = ".github/workflows/deploy-prod.yml"
+)
+
+// countGatedRe captures the variable name of a count-gated secret — a resource
+// whose existence is gated on a non-empty variable, so an empty value drops it.
+var countGatedRe = regexp.MustCompile(`count\s*=\s*var\.([a-z_][a-z0-9_]*)\s*==\s*""`)
+
+// tfVarRe captures a `TF_VAR_<name>: <value>` env assignment. A leading '#'
+// breaks the `^\s*TF_VAR_` anchor, so a commented-out var reads as omitted
+// (which it effectively is).
+var tfVarRe = regexp.MustCompile(`(?m)^\s*TF_VAR_([a-z_][a-z0-9_]*):\s*(.*)$`)
+
+// countGated returns the sorted, de-duplicated names of count-gated secrets in
+// a terraform secrets file. Each secret is two resources (the secret + its
+// version), both gated, so the names dedupe.
+func countGated(secretsTF string) []string {
+	seen := make(map[string]bool)
+	for _, m := range countGatedRe.FindAllStringSubmatch(secretsTF, -1) {
+		seen[m[1]] = true
+	}
+	names := make([]string, 0, len(seen))
+	for name := range seen {
+		names = append(names, name)
+	}
+	sort.Strings(names)
+	return names
+}
+
+// passedTFVars maps each TF_VAR_<name> the deploy workflow sets to its raw value.
+func passedTFVars(deployYML string) map[string]string {
+	out := make(map[string]string)
+	for _, m := range tfVarRe.FindAllStringSubmatch(deployYML, -1) {
+		out[m[1]] = strings.TrimSpace(m[2])
+	}
+	return out
+}
+
+// lint returns one message per violation: a count-gated secret whose TF_VAR_ is
+// missing from the deploy workflow, or present but not wired to a secret
+// reference (e.g. a `TF_VAR_x: ""` literal, which destroys the secret just like
+// omitting it).
+func lint(secretsTF, deployYML string) []string {
+	passed := passedTFVars(deployYML)
+	var violations []string
+	for _, name := range countGated(secretsTF) {
+		value, ok := passed[name]
+		if !ok {
+			violations = append(violations, fmt.Sprintf(
+				"deploy-prod.yml is missing TF_VAR_%s — it's count-gated, so an omitted apply DESTROYS the secret + strips its Cloud Run env", name))
+			continue
+		}
+		if !strings.Contains(value, "secrets.") {
+			violations = append(violations, fmt.Sprintf(
+				"TF_VAR_%s is set to %q, not a ${{ secrets.* }} reference — an empty value destroys the secret", name, value))
+		}
+	}
+	return violations
+}
+
+func run() error {
+	secretsTFPath := flag.String("secrets-tf", defaultSecretsTF, "path to the prod secrets.tf")
+	deployPath := flag.String("deploy-workflow", defaultDeployWorkflow, "path to deploy-prod.yml")
+	flag.Parse()
+
+	secretsTF, err := os.ReadFile(*secretsTFPath)
+	if err != nil {
+		return fmt.Errorf("read secrets.tf: %w", err)
+	}
+	deployYML, err := os.ReadFile(*deployPath)
+	if err != nil {
+		return fmt.Errorf("read deploy workflow: %w", err)
+	}
+
+	gated := countGated(string(secretsTF))
+	if len(gated) == 0 {
+		// Fail loud: a lint that finds no secrets is worse than none — it would
+		// pass everything. Almost certainly a wrong --secrets-tf path.
+		return fmt.Errorf("no count-gated secrets found in %s — check the path", *secretsTFPath)
+	}
+
+	violations := lint(string(secretsTF), string(deployYML))
+	if len(violations) > 0 {
+		fmt.Fprintf(os.Stderr,
+			"deploy-secret-lint: %d violation(s) — every count-gated prod secret must be passed to terraform apply:\n",
+			len(violations))
+		for _, v := range violations {
+			fmt.Fprintf(os.Stderr, "  - %s\n", v)
+		}
+		return fmt.Errorf("%d count-gated secret(s) not wired in %s", len(violations), *deployPath)
+	}
+
+	fmt.Printf("deploy-secret-lint: OK — all %d count-gated prod secrets are passed to terraform apply (%s)\n",
+		len(gated), strings.Join(gated, ", "))
+	return nil
+}
+
+func main() {
+	if err := run(); err != nil {
+		fmt.Fprintln(os.Stderr, "deploy-secret-lint:", err)
+		os.Exit(1)
+	}
+}
